# Konfigurasi Database
DB_DSN="host=localhost user=postgres password=password dbname=db_blockchain port=5432 sslmode=disable"

# Konfigurasi Server
PORT=8080

# Konfigurasi Hyperledger Fabric
FABRIC_MSP_ID=Org1MSP
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_CHANNEL=mychannel
FABRIC_CHAINCODE=audit_chaincode
FABRIC_TLS_CERT_PATH=./wallet/ca.crt
FABRIC_CERT_PATH=./wallet/user-cert.pem
FABRIC_KEY_PATH=./wallet/priv_sk